<{{ system_prompt_injection_tag }}>
<genesis_rules>
{{ genesis_rules | escape }}
</genesis_rules>
<persona_steering>
  <name>{{ persona_name | escape }}</name>
  {% if persona_background %}
  <background>{{ persona_background | escape }}</background>
  {% endif %}
  <tone>{{ persona_voice_tone | escape }}</tone>
  {% if persona_guidelines and persona_guidelines | length > 0 %}
  <guidelines>
  {% for rule in persona_guidelines %}
    <rule>{{ rule | escape }}</rule>
  {% endfor %}
  </guidelines>
  {% endif %}
  <thought_pattern>{{ persona_cot_template | escape }}</thought_pattern>
  <anchors>{{ persona_style_anchors | join(sep=", ") | escape }}</anchors>
</persona_steering>
{% if persona_forbidden_words and persona_forbidden_words | length > 0 %}
<forbidden_terms>
{% for term in persona_forbidden_words %}
  <term>{{ term | escape }}</term>
{% endfor %}
</forbidden_terms>
{% endif %}
{% if persona_metadata and persona_metadata | length > 0 %}
<persona_metadata>
{% for key, value in persona_metadata %}
  <entry key="{{ key | escape }}">{{ value | escape }}</entry>
{% endfor %}
</persona_metadata>
{% endif %}
<narrative_context>
{% for entry in narrative_entries %}
  <entry>{{ entry | escape }}</entry>
{% endfor %}
</narrative_context>
{% if skill_manuals and skill_manuals | length > 0 %}
<skill_injection>
  <instruction>You must adhere to the exact syntax and tool guidelines described in these manuals instead of making assumptions.</instruction>
  {% for manual in skill_manuals %}
  <manual>
    {{ manual | escape }}
  </manual>
  {% endfor %}
</skill_injection>
{% endif %}
<working_history>
{{ history | escape }}
</working_history>
</{{ system_prompt_injection_tag }}>
